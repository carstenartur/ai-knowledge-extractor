<?xml version="1.0" encoding="UTF-8"?>
<plugin>
  <name>AI Knowledge Maven Plugin</name>
  <description>Generates deterministic repository knowledge indexes and reports.</description>
  <groupId>org.aiknowledge</groupId>
  <artifactId>ai-knowledge-maven-plugin</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <goalPrefix>ai-knowledge</goalPrefix>
  <mojos>
    <mojo>
      <goal>generate</goal>
      <description>Generate AI knowledge artifacts.</description>
      <requiresDependencyResolution>runtime</requiresDependencyResolution>
      <requiresDependencyCollection>runtime</requiresDependencyCollection>
      <requiresDirectInvocation>false</requiresDirectInvocation>
      <requiresProject>true</requiresProject>
      <requiresReports>false</requiresReports>
      <aggregator>false</aggregator>
      <requiresOnline>false</requiresOnline>
      <inheritedByDefault>true</inheritedByDefault>
      <phase>generate-resources</phase>
      <implementation>org.aiknowledge.maven.GenerateGoal</implementation>
      <language>java</language>
      <instantiationStrategy>per-lookup</instantiationStrategy>
      <executionStrategy>once-per-session</executionStrategy>
      <threadSafe>true</threadSafe>
      <parameters>
        <parameter><name>basedir</name><type>java.io.File</type><required>true</required><editable>false</editable></parameter>
        <parameter><name>outputDirectory</name><type>java.io.File</type><required>false</required><editable>true</editable></parameter>
        <parameter><name>seedDirectory</name><type>java.io.File</type><required>false</required><editable>true</editable></parameter>
        <parameter><name>modelProfileDirectory</name><type>java.io.File</type><required>false</required><editable>true</editable></parameter>
        <parameter><name>failOnWarnings</name><type>boolean</type><required>false</required><editable>true</editable></parameter>
        <parameter><name>maxCognitiveDebt</name><type>double</type><required>false</required><editable>true</editable></parameter>
      </parameters>
      <configuration>
        <basedir implementation="java.io.File" default-value="${project.basedir}"/>
        <outputDirectory implementation="java.io.File" default-value="${project.build.directory}/ai-knowledge"/>
        <seedDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <modelProfileDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <failOnWarnings implementation="boolean" default-value="false"/>
        <maxCognitiveDebt implementation="double" default-value="100.0"/>
      </configuration>
    </mojo>
