<?xml version="1.0" encoding="UTF-8"?>
<plugin>
  <name>AI Knowledge Maven Plugin</name>
  <description>Generates deterministic repository knowledge indexes and reports.</description>
  <groupId>org.aiknowledge</groupId>
  <artifactId>ai-knowledge-maven-plugin</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <goalPrefix>ai-knowledge</goalPrefix>
  <mojos>
    <mojo><goal>generate</goal><implementation>org.aiknowledge.maven.GenerateGoal</implementation><language>java</language><phase>generate-resources</phase><requiresProject>true</requiresProject><threadSafe>true</threadSafe></mojo>
    <mojo><goal>analyze</goal><implementation>org.aiknowledge.maven.AnalyzeGoal</implementation><language>java</language><phase>verify</phase><requiresProject>true</requiresProject><threadSafe>true</threadSafe></mojo>
    <mojo><goal>optimize</goal><implementation>org.aiknowledge.maven.OptimizeGoal</implementation><language>java</language><phase>verify</phase><requiresProject>true</requiresProject><threadSafe>true</threadSafe></mojo>
    <mojo><goal>benchmark</goal><implementation>org.aiknowledge.maven.BenchmarkGoal</implementation><language>java</language><phase>verify</phase><requiresProject>true</requiresProject><threadSafe>true</threadSafe></mojo>
    <mojo><goal>check</goal><implementation>org.aiknowledge.maven.CheckGoal</implementation><language>java</language><phase>verify</phase><requiresProject>true</requiresProject><threadSafe>true</threadSafe></mojo>
  </mojos>
</plugin>
