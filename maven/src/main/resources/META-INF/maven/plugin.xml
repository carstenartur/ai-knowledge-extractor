<?xml version="1.0" encoding="UTF-8"?>
<plugin>
  <name>AI Knowledge Maven Plugin</name>
  <description>Generates deterministic repository knowledge indexes and reports.</description>
  <groupId>io.github.carstenartur</groupId>
  <artifactId>ai-knowledge-maven-plugin</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <goalPrefix>ai-knowledge</goalPrefix>
  <isolatedRealm>false</isolatedRealm>
  <inheritedByDefault>true</inheritedByDefault>
  <mojos>
    <mojo>
      <goal>generate</goal>
      <implementation>io.github.carstenartur.aiknowledge.maven.GenerateGoal</implementation>
      <language>java</language>
      <phase>generate-resources</phase>
      <requiresProject>true</requiresProject>
      <threadSafe>true</threadSafe>
      <configuration>
        <basedir implementation="java.io.File" default-value="${project.basedir}"/>
        <outputDirectory implementation="java.io.File" default-value="${project.build.directory}/ai-knowledge"/>
        <seedDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <modelProfileDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
      </configuration>
    </mojo>
    <mojo>
      <goal>analyze</goal>
      <implementation>io.github.carstenartur.aiknowledge.maven.ComplexityGoal</implementation>
      <language>java</language>
      <phase>verify</phase>
      <requiresProject>true</requiresProject>
      <threadSafe>true</threadSafe>
      <configuration>
        <basedir implementation="java.io.File" default-value="${project.basedir}"/>
        <outputDirectory implementation="java.io.File" default-value="${project.build.directory}/ai-knowledge"/>
        <seedDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <modelProfileDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
      </configuration>
    </mojo>
    <mojo>
      <goal>optimize</goal>
      <implementation>io.github.carstenartur.aiknowledge.maven.AdvisorGoal</implementation>
      <language>java</language>
      <phase>verify</phase>
      <requiresProject>true</requiresProject>
      <threadSafe>true</threadSafe>
      <configuration>
        <basedir implementation="java.io.File" default-value="${project.basedir}"/>
        <outputDirectory implementation="java.io.File" default-value="${project.build.directory}/ai-knowledge"/>
        <seedDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <modelProfileDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
      </configuration>
    </mojo>
    <mojo>
      <goal>benchmark</goal>
      <implementation>io.github.carstenartur.aiknowledge.maven.ProfileGoal</implementation>
      <language>java</language>
      <phase>verify</phase>
      <requiresProject>true</requiresProject>
      <threadSafe>true</threadSafe>
      <configuration>
        <basedir implementation="java.io.File" default-value="${project.basedir}"/>
        <outputDirectory implementation="java.io.File" default-value="${project.build.directory}/ai-knowledge"/>
        <seedDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <modelProfileDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
      </configuration>
    </mojo>
    <mojo>
      <goal>check</goal>
      <implementation>io.github.carstenartur.aiknowledge.maven.GateGoal</implementation>
      <language>java</language>
      <phase>verify</phase>
      <requiresProject>true</requiresProject>
      <threadSafe>true</threadSafe>
      <configuration>
        <basedir implementation="java.io.File" default-value="${project.basedir}"/>
        <outputDirectory implementation="java.io.File" default-value="${project.build.directory}/ai-knowledge"/>
        <seedDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <modelProfileDirectory implementation="java.io.File" default-value="${project.basedir}/ai-knowledge"/>
        <failOnWarnings implementation="boolean" default-value="false"/>
        <maxCognitiveDebt implementation="double" default-value="100.0"/>
      </configuration>
    </mojo>
  </mojos>
</plugin>
